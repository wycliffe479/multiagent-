# Copy this file to .env and fill in your values

# LLM Provider (OpenAI-compatible endpoint)
OPENCODE_API_KEY=your_api_key_here
OPENCODE_BASE_URL=https://api.minimaxi.chat/v1
MODEL_NAME=MiniMax-Text-01

# Optional: Slack Webhook URL for real notifications
# Leave blank to print to console instead
SLACK_WEBHOOK_URL=
